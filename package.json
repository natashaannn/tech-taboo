    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
